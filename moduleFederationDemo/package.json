{
  "name": "module-federation-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n host,remote -c cyan,magenta \"npm run dev:host\" \"npm run dev:remote\"",
    "dev:host": "webpack serve --config host/webpack.config.cjs",
    "dev:remote": "webpack serve --config remote/webpack.config.cjs",
    "build": "npm run build:remote && npm run build:host",
    "build:host": "webpack --config host/webpack.config.cjs --mode production",
    "build:remote": "webpack --config remote/webpack.config.cjs --mode production"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
